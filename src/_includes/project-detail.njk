---
layout: base.njk
---
<div class="project-header">
    <h1>{{ title }}</h1>
    {% if subtitle %}<p class="project-subtitle">{{ subtitle }}</p>{% endif %}
    {% if authors %}<p class="project-authors">{{ authors | markdown | safe }}</p>{% endif %}
    {% if affiliation %}<p class="project-affiliation">{{ affiliation }}</p>{% endif %}
    {% if tags %}
    <div class="tags">
        {% for tag in tags %}
            {% if tag != "projects" %} {# Eleventy might include the collection name in tags, let's filter it out #}
            <span class="tag">{{ tag }}</span>
            {% endif %}
        {% endfor %}
    </div>
    {% endif %}
</div>
{% if arxiv_link or paper_link or github_link or hf_link %}
<div class="project-actions">
    {% if arxiv_link %}
    <a class="project-btn project-btn--arxiv" href="{{ arxiv_link }}" target="_blank" rel="noopener">arXiv</a>
    {% endif %}
    {% if paper_link %}
    <a class="project-btn project-btn--paper" href="{{ paper_link }}" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" width="16" height="16"><path fill="currentColor" d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/></svg>
        Paper
    </a>
    {% endif %}
    {% if hf_link %}
    <a class="project-btn project-btn--hf" href="{{ hf_link }}" target="_blank" rel="noopener">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="16" height="16">
          <path d="M15.998 2.001A13.996 13.996 0 0 0 2 16a13.996 13.996 0 0 0 13.998 13.999A13.996 13.996 0 0 0 29.996 16 13.996 13.996 0 0 0 15.998 2.001zm0 25.998A11.996 11.996 0 0 1 4 16a11.996 11.996 0 0 1 11.998-11.999A11.996 11.996 0 0 1 27.996 16a11.996 11.996 0 0 1-11.998 11.999z" fill="currentColor"/>
          <path d="M10.999 11.002a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm10.001 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zM16 23.003c-3.13 0-5.83-2.07-6.8-4.99h13.6c-.97 2.92-3.67 4.99-6.8 4.99z" fill="currentColor"/>
        </svg>
        HuggingFace
    </a>
    {% endif %}
    {% if github_link %}
    <a class="project-btn project-btn--github" href="{{ github_link }}" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" width="16" height="16"><path fill="currentColor" d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
        GitHub
    </a>
    {% endif %}
</div>
{% endif %}
<hr>
{% if abstract %}
<h2>Abstract</h2>
<div class="pub-abstract" style="font-style:italic">{{ abstract | safe }}</div>
{% endif %}
<div class="project-body">
    {{ content | safe }}
</div>
{% if bibtex %}
<section class="project-citation">
    <h2>Citation</h2>
    <div class="pub-bibtex-wrap">
        <pre class="pub-bibtex"><code>{{ bibtex }}</code></pre>
        <button class="pub-copy-btn" onclick="navigator.clipboard.writeText(this.previousElementSibling.textContent).then(()=>{this.textContent=&quot;Copied!&quot;,setTimeout(()=>{this.textContent=&quot;Copy&quot;},1500)})">Copy</button>
    </div>
</section>
{% endif %}
