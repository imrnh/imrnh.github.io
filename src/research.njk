---
layout: base.njk
title: Research Notes · Imran Hossen
---
<div class="article-header">
    <h1>Research Notes</h1>
    <p class="text-dim">Curated overviews of research topics and completed studies.</p>
</div>
<div class="project-grid">
    {% for project in collections.research | reverse %}
    <a class="project-card" href="{{ project.url }}">
        <div class="project-card-thumb">
            {% if project.data.image %}
            <img src="{{ project.data.image }}" alt="{{ project.data.title }}">
            {% endif %}
        </div>
        <div class="project-card-body">
            <h3>{{ project.data.title }}</h3>
            <div class="meta">{{ project.data.subtitle }}</div>
            <div class="tldr">{{ project.data.tldr }}</div>
            <div class="tags">
                {% for tag in project.data.tags %}
                    {% if tag != "research" %}
                    <span class="tag">{{ tag }}</span>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
    </a>
    {% endfor %}
</div>
